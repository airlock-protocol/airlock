{
  "name": "airlock-client",
  "version": "0.1.0",
  "description": "HTTP client for the Agentic Airlock gateway (TypeScript)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "~5.6.3"
  },
  "keywords": [
    "airlock",
    "agents",
    "trust",
    "did",
    "a2a"
  ]
}
